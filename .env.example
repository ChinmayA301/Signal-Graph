# Database (Docker Compose default)
DATABASE_URL=postgresql+psycopg://signalgraph:signalgraph@localhost:5432/signalgraph

# GitHub API (optional; improves live ingestion; mock mode works without)
GITHUB_TOKEN=

# MOCK_MODE=true uses synthetic star histories and metadata for demos
MOCK_MODE=true

# API base URL as seen from the browser (Next.js server rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8000
